{
  "name": "fikir-fix-bot",
  "version": "1.0.0",
  "description": "FikirFix — Telegram home repair booking bot for Addis Ababa (in Amharic)",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build": "prisma generate",
    "start": "node src/index.js",
